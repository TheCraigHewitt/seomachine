# SEO Machine Environment Variables — Freaking Nomads
# Copy this file to data_sources/config/.env and fill in your actual values
# NEVER commit your .env file with real credentials!

# ============================================
# Google Analytics 4 Configuration
# ============================================
# Your GA4 Property ID (format: 123456789)
GA4_PROPERTY_ID=your_property_id_here

# Path to your GA4 service account JSON credentials file
# Get this from Google Cloud Console > APIs & Services > Credentials
GA4_CREDENTIALS_PATH=./credentials/ga4-credentials.json

# ============================================
# Google Search Console Configuration
# ============================================
# Your website URL as it appears in Search Console
# Include https:// and trailing slash
GSC_SITE_URL=https://freakingnomads.com/

# Path to your GSC service account JSON credentials file
# Can be the same file as GA4 if using the same service account
GSC_CREDENTIALS_PATH=./credentials/gsc-credentials.json

# ============================================
# DataForSEO API Configuration
# ============================================
# Your DataForSEO login email
DATAFORSEO_LOGIN=your_email@example.com

# Your DataForSEO API password
DATAFORSEO_PASSWORD=your_api_password_here

# ============================================
# Payload CMS Configuration (Publishing)
# ============================================
# Base URL of the Freaking Nomads Next.js / Payload CMS API
# Typically: https://freakingnomads.com/api
PAYLOAD_API_URL=https://freakingnomads.com/api

# API token for Payload CMS authentication
# Generate in Payload admin panel: Settings > API Keys (or equivalent)
PAYLOAD_API_TOKEN=your_payload_api_token_here

# The Payload collection name for blog posts
# Check your Payload schema — commonly "posts", "articles", or similar
PAYLOAD_COLLECTION=posts

# ============================================
# Optional: Site Information
# ============================================
COMPANY_NAME=Freaking Nomads
COMPANY_DOMAIN=freakingnomads.com
TARGET_INDUSTRY=digital-nomad

# Blog path — FN uses root-level slugs (no /blog/ prefix)
BLOG_PATH=/

# ============================================
# Setup Instructions
# ============================================
#
# 1. Google Analytics 4:
#    - Go to Google Cloud Console (console.cloud.google.com)
#    - Create or select a project
#    - Enable Google Analytics Data API
#    - Create service account and download JSON key
#    - Add service account email to GA4 property (Viewer role)
#    - Save JSON file to ./credentials/ga4-credentials.json
#
# 2. Google Search Console:
#    - Use same service account as GA4 or create new one
#    - Enable Google Search Console API in Cloud Console
#    - Add service account email as user in Search Console
#    - Save credentials to ./credentials/gsc-credentials.json
#
# 3. DataForSEO:
#    - Already configured as MCP server in this workspace
#    - For Python scripts: add your login and password here
#    - Get credentials from dataforseo.com dashboard
#
# 4. Payload CMS:
#    - Log into your Payload admin panel
#    - Navigate to Settings > API Keys (location varies by config)
#    - Create a new API key with read/write access to the posts collection
#    - Copy the token to PAYLOAD_API_TOKEN above
#    - Confirm your collection name matches PAYLOAD_COLLECTION
#    - Test with: python3 payload/payload_publisher.py --test
#
# 5. Copy this file:
#    cp .env.example data_sources/config/.env
#
# For detailed setup instructions, see data-sources-setup.md
